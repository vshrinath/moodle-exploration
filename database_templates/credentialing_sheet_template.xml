<?xml version="1.0" encoding="UTF-8"?>
<database>
  <name>Credentialing Sheet</name>
  <intro><![CDATA[<p>Monthly credentialing sheet for documenting surgical procedures and competency achievements.</p>
<p><strong>Submission Guidelines:</strong></p>
<ul>
<li>Submit one entry per month</li>
<li>Include accurate procedure counts for all categories</li>
<li>Document all competency achievements during the month</li>
<li>Obtain mentor verification and approval</li>
<li>Maintain cumulative tracking throughout training</li>
</ul>
<p><strong>Note:</strong> This data will be used for accreditation and certification purposes.</p>]]></intro>
  <introformat>1</introformat>
  <comments>1</comments>
  <timeavailablefrom>0</timeavailablefrom>
  <timeavailableto>0</timeavailableto>
  <timeviewfrom>0</timeviewfrom>
  <timeviewto>0</timeviewto>
  <requiredentries>0</requiredentries>
  <requiredentriestoview>0</requiredentriestoview>
  <maxentries>0</maxentries>
  <rssarticles>0</rssarticles>
  <singletemplate><![CDATA[<div class="credentialing-entry">
  <h3>Credentialing Sheet - [[month]] [[year]]</h3>
  <table class="generaltable">
    <tr><th colspan="2" class="section-header">Submission Details</th></tr>
    <tr><th>Month:</th><td>[[month]]</td></tr>
    <tr><th>Year:</th><td>[[year]]</td></tr>
    <tr><th>Submission Date:</th><td>[[submission_date]]</td></tr>
    
    <tr><th colspan="2" class="section-header">Cataract Procedures</th></tr>
    <tr><th>Phacoemulsification:</th><td>[[phaco_count]]</td></tr>
    <tr><th>SICS/ECCE:</th><td>[[sics_count]]</td></tr>
    <tr><th>IOL Implantation:</th><td>[[iol_count]]</td></tr>
    
    <tr><th colspan="2" class="section-header">Retina Procedures</th></tr>
    <tr><th>Vitrectomy:</th><td>[[vitrectomy_count]]</td></tr>
    <tr><th>Laser Photocoagulation:</th><td>[[laser_retina_count]]</td></tr>
    <tr><th>Intravitreal Injections:</th><td>[[injection_count]]</td></tr>
    
    <tr><th colspan="2" class="section-header">Cornea Procedures</th></tr>
    <tr><th>Keratoplasty:</th><td>[[keratoplasty_count]]</td></tr>
    <tr><th>Pterygium Surgery:</th><td>[[pterygium_count]]</td></tr>
    <tr><th>Corneal Cross-linking:</th><td>[[crosslinking_count]]</td></tr>
    
    <tr><th colspan="2" class="section-header">Glaucoma Procedures</th></tr>
    <tr><th>Trabeculectomy:</th><td>[[trabeculectomy_count]]</td></tr>
    <tr><th>Laser Trabeculoplasty:</th><td>[[laser_glaucoma_count]]</td></tr>
    <tr><th>Tube Shunt Surgery:</th><td>[[tube_shunt_count]]</td></tr>
    
    <tr><th colspan="2" class="section-header">Oculoplasty Procedures</th></tr>
    <tr><th>Lid Surgery:</th><td>[[lid_surgery_count]]</td></tr>
    <tr><th>DCR/DCT:</th><td>[[dcr_count]]</td></tr>
    <tr><th>Orbital Surgery:</th><td>[[orbital_count]]</td></tr>
    
    <tr><th colspan="2" class="section-header">Pediatric Procedures</th></tr>
    <tr><th>Strabismus Surgery:</th><td>[[strabismus_count]]</td></tr>
    <tr><th>Pediatric Cataract:</th><td>[[pediatric_cataract_count]]</td></tr>
    
    <tr><th colspan="2" class="section-header">Competency Achievements</th></tr>
    <tr><th>Competencies Achieved:</th><td>[[competencies_achieved]]</td></tr>
    <tr><th>Skills Demonstrated:</th><td>[[skills_demonstrated]]</td></tr>
    
    <tr><th colspan="2" class="section-header">Mentor Verification</th></tr>
    <tr><th>Approval Status:</th><td>[[approval_status]]</td></tr>
    <tr><th>Mentor Comments:</th><td>[[mentor_comments]]</td></tr>
    <tr><th>Approval Date:</th><td>[[approval_date]]</td></tr>
  </table>
  <div class="cred-actions">
    [[edit]] [[delete]] [[approve]]
  </div>
</div>]]></singletemplate>
  <listtemplate><![CDATA[<div class="credentialing-list">
  <h2>Credentialing Sheets</h2>
  <table class="generaltable">
    <thead>
      <tr>
        <th>Month/Year</th>
        <th>Total Procedures</th>
        <th>Competencies</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      ##entries##
    </tbody>
  </table>
</div>]]></listtemplate>
  <listtemplateheader></listtemplateheader>
  <listtemplatefooter></listtemplatefooter>
  <addtemplate></addtemplate>
  <rsstemplate></rsstemplate>
  <rsstitletemplate></rsstitletemplate>
  <csstemplate><![CDATA[.credentialing-entry {
  border: 1px solid #ddd;
  padding: 15px;
  margin: 10px 0;
  border-radius: 5px;
}
.credentialing-entry h3 {
  margin-top: 0;
  color: #0066cc;
}
.section-header {
  background-color: #f0f0f0;
  font-weight: bold;
  padding: 8px !important;
}
.cred-actions {
  margin-top: 10px;
  text-align: right;
}]]></csstemplate>
  <jstemplate></jstemplate>
  <asearchtemplate></asearchtemplate>
  <approval>1</approval>
  <manageapproved>1</manageapproved>
  <fields>
