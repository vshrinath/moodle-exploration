# Moodle Docker Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# Database Configuration
MARIADB_USER=bn_moodle
MARIADB_DATABASE=bitnami_moodle
MARIADB_PASSWORD=YOUR_SECURE_PASSWORD_HERE
MARIADB_ROOT_PASSWORD=YOUR_SECURE_ROOT_PASSWORD_HERE

# Moodle Configuration
BITNAMI_DEBUG=false

# Security Notes:
# 1. Generate strong passwords using: openssl rand -base64 32
# 2. Use different passwords for MARIADB_PASSWORD and MARIADB_ROOT_PASSWORD
# 3. Set BITNAMI_DEBUG=false in production
# 4. Ensure .env is in .gitignore
