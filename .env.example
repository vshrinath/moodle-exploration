# Moodle Docker Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# MoodleHQ + MySQL Dev Stack
MOODLEHQ_DB_NAME=moodle
MOODLEHQ_DB_USER=moodle
MOODLEHQ_DB_PASSWORD=YOUR_SECURE_MOODLEHQ_DB_PASSWORD_HERE
MOODLEHQ_DB_ROOT_PASSWORD=YOUR_SECURE_MOODLEHQ_DB_ROOT_PASSWORD_HERE
MOODLEHQ_WEB_PORT=8081
MOODLEHQ_WWWROOT=http://127.0.0.1:8081
MOODLEHQ_ADMIN_USER=admin
MOODLEHQ_ADMIN_PASS=YOUR_SECURE_MOODLEHQ_ADMIN_PASSWORD_HERE
MOODLEHQ_ADMIN_EMAIL=admin@example.com
MOODLEHQ_SITE_FULLNAME=SCEH Fellowship Training
MOODLEHQ_SITE_SHORTNAME=SCEH LMS
MOODLEHQ_CRON_INTERVAL=60

# Security Notes:
# 1. Generate strong passwords using: openssl rand -base64 32
# 2. Use different passwords for MOODLEHQ_DB_PASSWORD and MOODLEHQ_DB_ROOT_PASSWORD
# 3. Ensure .env is in .gitignore
