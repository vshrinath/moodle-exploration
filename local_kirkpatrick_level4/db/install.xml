<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/kirkpatrick_level4/db" VERSION="20250117" COMMENT="Kirkpatrick Level 4 external database integration"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="kirkpatrick_level4_results" COMMENT="Stores Level 4 organizational results data">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="programid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="measurement_period" TYPE="char" LENGTH="50" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="organization_unit" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="patient_outcomes" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="cost_savings" TYPE="number" LENGTH="15" DECIMALS="2" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="quality_metrics" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="roi_calculation" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="productivity_improvement" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="safety_indicators" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="external_source" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="sync_status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending" SEQUENCE="false"/>
        <FIELD NAME="last_sync" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="programid" TYPE="foreign" FIELDS="programid" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="measurement_period" UNIQUE="false" FIELDS="measurement_period"/>
        <INDEX NAME="sync_status" UNIQUE="false" FIELDS="sync_status"/>
      </INDEXES>
    </TABLE>
    
    <TABLE NAME="kirkpatrick_external_sources" COMMENT="Configuration for external data sources">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="source_type" TYPE="char" LENGTH="50" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="connection_string" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="api_endpoint" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="api_key" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="sync_frequency" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="86400" SEQUENCE="false"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" SEQUENCE="false"/>
        <FIELD NAME="last_sync" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="source_type" UNIQUE="false" FIELDS="source_type"/>
        <INDEX NAME="enabled" UNIQUE="false" FIELDS="enabled"/>
      </INDEXES>
    </TABLE>
    
    <TABLE NAME="kirkpatrick_learner_outcomes" COMMENT="Maps learners to organizational outcomes">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="programid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="level4_resultid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="contribution_score" TYPE="number" LENGTH="5" DECIMALS="2" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="correlation_strength" TYPE="char" LENGTH="20" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="programid" TYPE="foreign" FIELDS="programid" REFTABLE="course" REFFIELDS="id"/>
        <KEY NAME="level4_resultid" TYPE="foreign" FIELDS="level4_resultid" REFTABLE="kirkpatrick_level4_results" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_programid" UNIQUE="false" FIELDS="userid,programid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
